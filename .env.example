# ==============================================================================
# CIVY CONFIGURATION GUIDE (2026)
# ==============================================================================
# This file serves as a template for your local .env file.
# DUPLICATE this file, rename it to .env, and fill in the values.
#
# 🚨 SECURITY WARNING: Never commit your .env file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SUPABASE CONFIGURATION (Database & Auth)
# ------------------------------------------------------------------------------
# Create a new project at https://supabase.com/dashboard
# Go to Project Settings -> API to find these values.

# The URL of your Supabase project instance
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# The "anon" public key - safe to use in the browser
# IMPORTANT: This must match process.env.NEXT_PUBLISHABLE_SUPABASE_KEY in the code
NEXT_PUBLISHABLE_SUPABASE_KEY=your_supabase_anon_key

# The "service_role" secret key - server-side ONLY. Never expose this to the client.
# Used for administrative tasks and webhooks.
SUPABASE_SECRET_KEY=your_supabase_secret_key

# ------------------------------------------------------------------------------
# 2. APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------

# The base URL of your application.
# - Local development: http://localhost:3000
# - Production: https://your-domain.com
# IMPORTANT: This URL must be added to "Redirect URLs" in Supabase Auth settings.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 3. PAYMENT CONFIGURATION (PayPal)
# ------------------------------------------------------------------------------
# Create an app in the PayPal Developer Dashboard: https://developer.paypal.com
# Toggle to "Live" for production keys.

# PayPal Client ID (App Settings -> Credentials)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id

# PayPal Secret Key (App Settings -> Credentials)
PAYPAL_SECRET=your_paypal_secret

# PayPal Webhook ID (App Settings -> Webhooks)
# Create a webhook listener for 'BILLING.SUBSCRIPTION.*' events.
# The URL should be: [NEXT_PUBLIC_SITE_URL]/api/webhooks/paypal
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# PayPal API Base URL
# - Sandbox: https://api-m.sandbox.paypal.com (default if unset)
# - Production: https://api-m.paypal.com
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# ------------------------------------------------------------------------------
# 4. SUBSCRIPTION PLANS
# ------------------------------------------------------------------------------
# Create these plans in PayPal Sandbox/Live -> App -> Subscriptions.
# Or use the "Create Plan" API to generate these IDs.
# Format: P-xxxxxxxxxxxxxxxxxxxxxxxx

NEXT_PUBLIC_PAYPAL_PLAN_MONTHLY=P-your_monthly_plan_id
NEXT_PUBLIC_PAYPAL_PLAN_QUARTERLY=P-your_quarterly_plan_id
NEXT_PUBLIC_PAYPAL_PLAN_YEARLY=P-your_yearly_plan_id

# ------------------------------------------------------------------------------
# 5. OAUTH AUTHENTICATION PROVIDERS
# ------------------------------------------------------------------------------
# These are configured directly in the Supabase Dashboard.
# Authentication -> Providers -> [Select Provider] -> Enable
#
# You will need to obtain Client IDs and Secrets from each provider's developer console.
#
# Callback URL for ALL providers:
# https://[your-project-id].supabase.co/auth/v1/callback
#
# Supported Providers in Civy:
# - Google (console.cloud.google.com)
# - GitHub (github.com/settings/developers)
# - Discord (discord.com/developers/applications)
# - Slack (api.slack.com/apps)
#
# No extra .env keys are needed here; Supabase handles the secrets internally.
# Enable the ones you want to support in the dashboard.

# ------------------------------------------------------------------------------
# 6. AI CONFIGURATION (Open Router)
# ------------------------------------------------------------------------------
# Sign up at https://openrouter.ai/keys to get an API key.
# The "openrouter/free" model is used by default (no cost).
# Adding an API key increases reliability and rate limits.
# OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ------------------------------------------------------------------------------
# 7. GUMROAD CONFIGURATION
# ------------------------------------------------------------------------------
# Your Gumroad store subdomain (e.g., "civycv" for civycv.gumroad.com)
NEXT_PUBLIC_GUMROAD_STORE_ID=

# Gumroad OAuth credentials (Settings -> Advanced -> Register application)
GUMROAD_APPLICATION_ID=
GUMROAD_APPLICATION_SECRET=

# Gumroad access token (generated after creating the OAuth application)
GUMROAD_ACCESS_TOKEN=
